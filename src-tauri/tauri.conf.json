{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HidrViewer",
  "version": "0.0.1",
  "identifier": "br.com.jhulia.hidrviewer",
  "build": {
    "beforeDevCommand": "npx http-server ../frontend -p 8080",
  "devUrl": "http://127.0.0.1:8080",
  "frontendDist": "../frontend"
},
  "app": {
    "windows": [
      {
        "title": "HidrViewer",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
